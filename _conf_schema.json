{
  "wecom_corp_id": {
    "type": "string",
    "description": "企业微信 CorpID",
    "hint": "用于获取 access_token。"
  },
  "wecom_kf_secret": {
    "type": "string",
    "description": "微信客服 Secret",
    "hint": "用于获取 access_token，并调用微信客服接口（如获取客户基础信息）。"
  },
  "enable_wecom_name_lookup": {
    "type": "bool",
    "description": "是否启用微信客服昵称查询",
    "default": true
  },
  "stats_storage": {
    "type": "object",
    "description": "统计存储配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "是否启用持久化统计",
        "default": true
      },
      "file_name": {
        "type": "string",
        "description": "统计文件名",
        "default": "homework_stats.json"
      },
      "keep_latest_records": {
        "type": "int",
        "description": "每个用户保留的最近请求时间条数，0 表示不限制",
        "default": 0
      }
    }
  },
  "log_settings": {
    "type": "object",
    "description": "日志配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "是否输出作业请求日志",
        "default": true
      },
      "mask_user_id": {
        "type": "bool",
        "description": "是否对 user_id 做脱敏",
        "default": true
      },
      "template": {
        "type": "string",
        "description": "日志模板",
        "default": "📊 作业请求 | user_id={user_id} | user_name={user_name} [api={api}] | platform={platform} | count={count} | time={time}"
      }
    }
  },
  "image_compression": {
    "type": "object",
    "description": "图片压缩配置",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "是否启用图片压缩",
        "default": false
      },
      "quality": {
        "type": "int",
        "description": "压缩质量(1-100),数值越小压缩率越高",
        "default": 85
      },
      "max_width": {
        "type": "int",
        "description": "最大宽度(像素),超过则等比缩放,0表示不限制",
        "default": 1920
      },
      "max_height": {
        "type": "int",
        "description": "最大高度(像素),超过则等比缩放,0表示不限制",
        "default": 1080
      }
    }
  }
}